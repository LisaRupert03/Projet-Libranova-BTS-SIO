<%- include('../partials/header') %>

<div class="container mt-5">

  <h2 class="text-center mb-4">📚 Catalogue des livres</h2>

  <div class="row">

    <% if (books && books.length > 0) { %>

      <% books.forEach(book => { %>

        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow">

            <!-- IMAGE -->
            <img src="<%= book.image || '/images/default.jpg' %>" 
                 class="card-img-top"
                 style="height:200px; object-fit:cover;">

            <div class="card-body d-flex flex-column">

              <h5 class="card-title"><%= book.titre %></h5>

              <p class="text-muted">
  <a 
    href="https://fr.wikipedia.org/wiki/<%= book.auteur.replace(/ /g, '_') %>" 
    target="_blank"
    class="text-decoration-none text-dark"
  >
    <%= book.auteur %>
  </a>
</p>

              <!-- DESCRIPTION -->
              <p class="card-text">
                <%= book.description || "Pas de description disponible" %>
              </p>

              <p>💰 <strong><%= book.prix %> €</strong></p>

              <!-- STOCK -->
              <p>
                📦 
                <% if (book.stock > 0) { %>
                  <span class="text-success">Disponible</span>
                <% } else { %>
                  <span class="text-danger">Rupture de stock</span>
                <% } %>
              </p>

              <!-- AJOUT PANIER -->
              <% if (book.stock > 0) { %>
                <form action="/cart/add/<%= book.id %>" method="POST" class="mt-auto">
                  <button class="btn btn-primary w-100">
                    Ajouter au panier
                  </button>
                </form>
              <% } else { %>
                <button class="btn btn-secondary w-100 mt-auto" disabled>
                  Indisponible
                </button>
              <% } %>

            </div>

          </div>
        </div>

      <% }) %>

    <% } else { %>

      <p class="text-center">Aucun livre disponible</p>

    <% } %>

  </div>

</div>

<%- include('../partials/footer') %>