<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>IRIS Toulouse</title>

<link rel='stylesheet' href='/stylesheets/style.css'>
<link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">

<style>

/* Couleur principale */
.nav-color{
  background: linear-gradient(90deg,#f9b104,#ffcc4d);
}

/* Navbar plus moderne */
.navbar{
  padding:10px 20px;
  box-shadow:0 3px 8px rgba(0,0,0,0.1);
}

/* Logo */
.navbar-brand{
  font-weight:700;
  letter-spacing:1px;
  font-size:1.1rem;
}

/* Liens */
.navbar .nav-link{
  font-size:0.9rem;
  margin-right:10px;
  transition:0.2s;
}

.navbar .nav-link:hover{
  color:#ffffff !important;
  transform:scale(1.05);
}

/* Dropdown */
.dropdown-menu{
  border-radius:10px;
  border:none;
  box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.dropdown-item{
  font-size:0.85rem;
}

.dropdown-item:hover{
  background:#f9b104;
  color:white;
}

/* Barre de recherche */
.form-control{
  font-size:0.85rem;
}

/* Boutons */
.btn-sm{
  font-size:0.8rem;
  border-radius:6px;
}

/* Espace entre boutons */
.nav-buttons{
  display:flex;
  align-items:center;
  gap:10px;
}

</style>

</head>

<body>

<nav class="navbar navbar-expand-lg navbar-light nav-color">

<div class="container-fluid">

<a class="navbar-brand" href="/">IRIS TOULOUSE</a>

<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse" id="navbarNav">

<ul class="navbar-nav me-auto">

<li class="nav-item">
<a class="nav-link active" href="/">Accueil</a>
</li>

<% if (user && (user.role === 'etudiant' || user.role === 'enseignant')) { %>

<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" href="/etudiants" role="button" data-bs-toggle="dropdown">
Gestion des étudiants
</a>

<ul class="dropdown-menu">
<li><a class="dropdown-item" href="/etudiants">Liste des étudiants</a></li>
<li><a class="dropdown-item" href="/etudiants/ajouter">Ajouter un étudiant</a></li>
</ul>

</li>

<% } %>


<% if (user && (user.role === 'enseignant' || user.role === 'admin')) { %>

<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" href="/enseignants" role="button" data-bs-toggle="dropdown">
Gestion des enseignants
</a>

<ul class="dropdown-menu">
<li><a class="dropdown-item" href="/enseignants">Liste des enseignants</a></li>
<li><a class="dropdown-item" href="/enseignants/ajouter">Ajouter un enseignant</a></li>
</ul>

</li>

<% } %>


<% if (user && user.role === 'enseignant') { %>

<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" href="/cours" role="button" data-bs-toggle="dropdown">
Gestion des cours
</a>

<ul class="dropdown-menu">
<li><a class="dropdown-item" href="/cours">Liste des cours</a></li>
<li><a class="dropdown-item" href="/cours/ajouter">Ajouter un cours</a></li>
</ul>

</li>

<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" href="/notes" role="button" data-bs-toggle="dropdown">
Gestion des notes
</a>

<ul class="dropdown-menu">
<li><a class="dropdown-item" href="/notes">Liste des notes</a></li>
<li><a class="dropdown-item" href="/notes/ajouter">Ajouter une note</a></li>
</ul>

</li>

<% } %>


<% if (user && user.role === 'admin') { %>

<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" href="/salles" role="button" data-bs-toggle="dropdown">
Gestion des salles
</a>

<ul class="dropdown-menu">
<li><a class="dropdown-item" href="/salles">Liste des salles</a></li>
<li><a class="dropdown-item" href="/salles/ajouter">Ajouter une salle</a></li>
</ul>

</li>

<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" href="/users" role="button" data-bs-toggle="dropdown">
Gestion des utilisateurs
</a>

<ul class="dropdown-menu">
<li><a class="dropdown-item" href="/users">Liste des utilisateurs</a></li>
<li><a class="dropdown-item" href="/users/ajouter">Ajouter un utilisateur</a></li>
</ul>

</li>

<li class="nav-item dropdown">
<a class="nav-link dropdown-toggle" href="/contacts" role="button" data-bs-toggle="dropdown">
Gestion des contacts
</a>

<ul class="dropdown-menu">
<li><a class="dropdown-item" href="/contacts">Liste des contacts</a></li>
<li><a class="dropdown-item" href="/contacts/ajouter">Contactez nous</a></li>
</ul>

</li>

<% } %>

<li class="nav-item">
<a class="nav-link" href="#">À propos</a>
</li>

</ul>

<form class="d-flex me-3" role="search">
<input class="form-control me-2" type="search" placeholder="Rechercher">
<button class="btn btn-outline-dark btn-sm" type="submit">Search</button>
</form>


<div class="nav-buttons">

<% if (user) { %>

<form action="/api/logout" method="POST">
<button type="submit" class="btn btn-danger btn-sm">Déconnexion</button>
</form>

<% } else { %>

<a class="btn btn-outline-dark btn-sm" href="/login">Connexion</a>
<a class="btn btn-dark btn-sm" href="/register">Inscription</a>

<% } %>

</div>

</div>
</div>

</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>