<%- include('../partials/header') %>

<div class="container mt-5">

  <div class="hero">
    <h1>📩 Contact</h1>
    <p class="text-muted">Une question ? Contactez-nous</p>
  </div>

  <div class="card p-4">

    <form>

      <div class="mb-3">
        <label>Nom</label>
        <input type="text" class="form-control">
      </div>

      <div class="mb-3">
        <label>Email</label>
        <input type="email" class="form-control">
      </div>

      <div class="mb-3">
        <label>Message</label>
        <textarea class="form-control"></textarea>
      </div>

      <button class="btn">Envoyer</button>

    </form>

  </div>

</div>

<%- include('../partials/footer') %>